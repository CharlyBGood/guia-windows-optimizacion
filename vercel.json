{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/windows-repara/", "permanent": false }
  ],
  "rewrites": [
    { "source": "/windows-repara", "destination": "/index.html" },
    { "source": "/windows-repara/", "destination": "/index.html" },
    { "source": "/windows-repara/(.*)", "destination": "/$1" }
  ]
}
